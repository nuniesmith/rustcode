# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/

# ---------------------------------------------------------------------------
# IDE & Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.iml
*.ipr
*.iws
.fleet/
.zed/
*.swp
*.swo
*~
\#*\#
.DS_Store
Thumbs.db

