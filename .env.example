# =============================================================================
# rustcode — example environment configuration
# =============================================================================
# Copy this file to `.env` and fill in the values for your deployment.
# Variables without a default need to be set explicitly when in use.

# -----------------------------------------------------------------------------
# LLM providers (Claude is the primary path; XAI/Ollama are fallbacks)
# -----------------------------------------------------------------------------

# Anthropic API key — when set, Claude becomes the primary routing target.
# Opus 4.7 handles planner tasks (architecture, review); Sonnet 4.6 handles
# executor tasks (scaffold, extract, tag).
ANTHROPIC_API_KEY=

# Optional: override the default Claude model slugs.
# RC_PLANNER_MODEL=claude-opus-4-7
# RC_EXECUTOR_MODEL=claude-sonnet-4-6

# Optional: override the Anthropic API base URL (e.g. for self-hosted proxies).
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# xAI (Grok) API key — fallback when ANTHROPIC_API_KEY is absent.
XAI_API_KEY=

# Optional Grok model override.
# REMOTE_MODEL=grok-4-1-fast-reasoning

# Ollama local inference (optional).
# OLLAMA_BASE_URL=http://localhost:11434
# LOCAL_MODEL=qwen2.5-coder:7b
# OLLAMA_ENABLED=false

# Force every request through the remote model, skipping local routing.
# FORCE_REMOTE_MODEL=false

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://rustcode:changeme@localhost:5432/rustcode

# -----------------------------------------------------------------------------
# Proxy authentication
# -----------------------------------------------------------------------------

# Comma-separated bearer tokens accepted by /v1/chat/completions and /api/*.
# Leave empty to disable auth (development only — logs a loud warning).
RUSTCODE_PROXY_API_KEYS=

# Set to `true` to disable auth entirely (dev only).
# RC_AUTH_DISABLED=false

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------

GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Repository indexing & sync
# -----------------------------------------------------------------------------

# Directory where indexed repos are cloned (default: /app/repos).
# REPOS_DIR=/app/repos

# Auto-sync interval in seconds (default: 300).
# REPO_SYNC_INTERVAL_SECS=300

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# HOST=0.0.0.0
# PORT=3500

# -----------------------------------------------------------------------------
# Caching (optional Redis)
# -----------------------------------------------------------------------------

# REDIS_URL=redis://localhost:6379
# CACHE_PREFIX=rustcode:
